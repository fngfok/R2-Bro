<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header>
        <h1>🤖 R2 Bro</h1>
        <nav>
            <a href="/">Home</a>
        </nav>
    </header>
    <main id="main-content">
        <h2>Player Profile</h2>
        <% if (player && player.name) { %>
            <p><strong>Name:</strong> <%= player.name %></p>
            <p>
                <strong>Ally Code:</strong> <span id="player-ally-code"><%= player.allyCode %></span>
                <button id="copy-ally-code" class="search-button" aria-label="Copy Ally Code" title="Copy to clipboard">Copy</button>
            </p>
            <p><strong>Level:</strong> <%= player.level %></p>
            <p><strong>GP:</strong> <span title="<%= player.getGalacticPower().toLocaleString() %>"><%= (player.getGalacticPower() / 1e6).toFixed(2) %>M</span></p>
            <% const guildInfo = player.getGuildInfo(); %>
            <% if (guildInfo.guildName) { %>
                <p><strong>Guild:</strong> <%= guildInfo.guildName %></p>
            <% } %>
            <div class="profile-actions">
                <a href="/" class="search-button">Search Another Player</a>
            </div>
        <% } else { %>
            <p>Player not found.</p>
            <div class="profile-actions">
                <a href="/" class="search-button">Back to Search</a>
            </div>
        <% } %>
    </main>
    <footer>
        <p>&copy; 2025 R2 Bro</p>
    </footer>
    <script src="/js/script.js"></script>
</body>
</html>
